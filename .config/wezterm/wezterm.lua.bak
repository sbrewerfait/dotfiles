--[[
============================
Session/Workspace Launcher (tmuxinator/sesh-style)
============================
]]
--

local function zsh(cmd)
	return { "zsh", "-lc", cmd }
end

local function switch_to_workspace(window, pane, name)
	window:perform_action(act.SwitchToWorkspace({ name = name }), pane)
end

local function workspace_seems_built(window)
	local mw = window:mux_window()
	if not mw then
		return false
	end
	-- Heuristic: if there is more than 1 tab, assume we've already built it.
	return #mw:tabs() > 1
end

local function ensure_code_workspace(window, pane)
	switch_to_workspace(window, pane, "code")

	if workspace_seems_built(window) then
		return
	end

	local mw = window:mux_window()
	local tab0 = mw:active_tab()
	local pane0 = tab0:active_pane()
	tab0:set_title("config")

	-- config tab: even-horizontal
	pane0:spawn_command_in_pane({ args = zsh("cd ~ && clear") })
	pane0:split({
		direction = "Right",
		size = 0.50,
		args = zsh("cd /Users/sbrewer/.config && nvim"),
	})

	-- bash tab:
	-- left = nvim in bash scripts dir
	-- right = two stacked cli panes
	local bash_tab, bash_pane = mw:spawn_tab({ args = zsh("cd ~ && clear") })
	bash_tab:set_title("bash")

	bash_pane:spawn_command_in_pane({ args = zsh("cd /Volumes/sbrewer/scripts.new/bash && nvim") })

	local bash_right = bash_pane:split({
		direction = "Right",
		size = 0.44,
		args = zsh("clear"),
	})
	bash_right:split({
		direction = "Bottom",
		size = 0.50,
		args = zsh("clear"),
	})

	-- filepro tab: 2x2 grid
	local fp_tab, fp_pane = mw:spawn_tab({ args = zsh("cd ~ && clear") })
	fp_tab:set_title("filepro")

	local fp_right = fp_pane:split({ direction = "Right", size = 0.50, args = zsh("cd ~ && clear") })
	fp_pane:split({ direction = "Bottom", size = 0.50, args = zsh("cd ~ && clear") })
	fp_right:split({ direction = "Bottom", size = 0.50, args = zsh("cd ~ && clear") })
end

local function ensure_notes_workspace(window, pane)
	switch_to_workspace(window, pane, "notes")

	local mw = window:mux_window()
	local tab0 = mw:active_tab()
	tab0:set_title("notes")

	-- Run in the active pane by "typing" the command
	local p = tab0:active_pane()
	p:send_text("cd /Users/sbrewer/vault/sbrewer-dev && nvim\n")
end

local function ensure_tunes_workspace(window, pane)
	switch_to_workspace(window, pane, "tunes")

	local mw = window:mux_window()
	local tab0 = mw:active_tab()
	tab0:set_title("spotify")

	local p = tab0:active_pane()
	p:send_text("spotify\n")
end

